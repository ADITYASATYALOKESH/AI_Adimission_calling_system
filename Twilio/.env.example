# ─── SERVER ──────────────────────────────────────────────
PORT=3000
# Public URL (ngrok / cloud host) — Twilio posts webhooks here
SERVER_URL=https://your-ngrok-url.ngrok.io

# ─── TWILIO ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# ─── SARVAM AI ───────────────────────────────────────────
SARVAM_API_KEY=sk_r5y8mo18_r7pvbcVHpcMX3N3jTqha4JNs
SARVAM_STT_MODEL=saarika:v2
SARVAM_STT_LANGUAGE=hi-IN
SARVAM_TTS_SPEAKER=meera
SARVAM_TTS_LANGUAGE=hi-IN
SARVAM_TTS_MODEL=bulbul:v1
SARVAM_TTS_SAMPLE_RATE=8000

# ─── RAG ENDPOINT ────────────────────────────────────────
RAG_ENDPOINT=http://localhost:3001/ask

# ─── OLLAMA ──────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=admissionmodel

# ─── REDIS ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=3600

# ─── VAD SETTINGS ────────────────────────────────────────
# Energy threshold (0–32767) below which is silence
SILENCE_ENERGY_THRESHOLD=200
# Consecutive silent chunks (20ms each) needed to finalise utterance
SILENCE_CHUNK_COUNT=75
# Minimum speech chunks before we process
MIN_SPEECH_CHUNKS=15

# ─── SENTENCE AGGREGATION ────────────────────────────────
# Min words to trigger TTS even without sentence-ending punctuation
MIN_WORDS_FOR_TTS=8
# Max characters to buffer before forcing sentence break
MAX_SENTENCE_CHARS=300

# ─── LATENCY TARGETS (ms) ────────────────────────────────
TARGET_STT_MS=500
TARGET_RAG_FIRST_TOKEN_MS=500
TARGET_SENTENCE_DETECT_MS=300
TARGET_TTS_MS=800
TARGET_BARGE_IN_MS=150

# ─── MISC ────────────────────────────────────────────────
LOG_LEVEL=INFO
NODE_ENV=production
